# StockM v1.0 — environment variables template
# Copy to .env and fill in real values. NEVER commit .env.

# ── Data sources ─────────────────────────────────────────────
# API keys for paid market-data providers (optional in v1; yfinance needs none)
DATA_PROVIDER_KEY=
POLYGON_API_KEY=
ALPHAVANTAGE_API_KEY=

# ── Experiment tracking ──────────────────────────────────────
MLFLOW_TRACKING_URI=sqlite:///experiments/mlflow.db
MLFLOW_EXPERIMENT_NAME=stockM_v1

# ── DVC remote (for data/model versioning) ───────────────────
DVC_REMOTE_STORAGE=
# e.g. s3://my-bucket/stockM-dvc  or  /path/to/local/remote

# ── API / serving ────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000
API_WORKERS=4
API_LOG_LEVEL=info

# ── Logging ──────────────────────────────────────────────────
LOG_LEVEL=INFO
LOG_FORMAT=json            # json | console
LOG_DIR=logs

# ── Secrets (do not commit) ───────────────────────────────────
# Add provider-specific credentials below as the project grows.
